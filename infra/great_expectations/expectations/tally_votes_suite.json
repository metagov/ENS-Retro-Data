{
  "expectation_suite_name": "tally_votes_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 1000, "max_value": 100000}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "voter"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "voter_ens"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "support"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "tx_hash"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "chain_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "proposal_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "voter"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "proposal_id"}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "voter",
        "regex": "^0x[a-fA-F0-9]{40}$"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "support",
        "value_set": ["for", "against", "abstain"]
      }
    }
  ],
  "meta": {
    "great_expectations_version": "1.12.3"
  }
}
