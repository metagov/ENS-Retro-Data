{
  "expectation_suite_name": "tally_delegates_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 1000, "max_value": 200000}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "address"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "voting_power"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "delegators_count"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "twitter"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "chain_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "token_symbol"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "address"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "id"}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "address",
        "regex": "^0x[a-fA-F0-9]{40}$"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "twitter",
        "regex": "^@?[a-zA-Z0-9_]{1,15}$"
      }
    }
  ],
  "meta": {
    "great_expectations_version": "1.12.3"
  }
}
