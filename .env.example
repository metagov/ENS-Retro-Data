# ENS-Retro-Data — Environment Variables
#
# Copy this file to `.env` and fill in the keys you need. You only have to
# set the keys for the parts of the system you actually run — nothing is
# globally required.
#
# NEVER commit `.env`. It's in .gitignore.

# ─── Dagster (local orchestration) ─────────────────────────────────────────
# Point this at the repo's .dagster/ directory so Dagster finds its instance
# config, run history, and LFS-tracked storage.
DAGSTER_HOME=/absolute/path/to/ENS-Retro-Data/.dagster

# ─── Data ingest (bronze layer) ────────────────────────────────────────────
# Needed by: infra/ingest/etherscan_api.py, bronze/on-chain/scripts/*
# Get a free key at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Needed by: infra/ingest/tally_api.py (currently frozen — Tally.xyz shutdown)
# Legacy historical data is checked in; you only need this if you try to
# re-run the tally assets.
TALLY_API_KEY=

# Needed by: infra/ingest/oso_api.py (GitHub activity via Open Source Observer)
# Get a key at https://www.opensource.observer/
OSO_API_KEY=

# ─── Dashboard + ChatKit (dashboards/app.py, dashboards/scripts/chat_*) ────
# OpenAI API key for minting ChatKit session tokens and uploading gold
# table snapshots to the OpenAI vector store.
OPENAI_API_KEY=

# Separate key for Agent Builder workflow API calls (if your org uses
# distinct workflow-scoped keys). Fall back to OPENAI_API_KEY if unset.
OPENAI_WORKFLOWS_API_KEY=

# Agent Builder workflow ID — the ChatKit widget posts to this workflow.
# Create a workflow at https://platform.openai.com/agent-builder
WORKFLOW_ID=

# ─── MCP API server (dashboards/api.py) ────────────────────────────────────
# Bearer token protecting /api/* and /mcp endpoints. The server fails closed
# if this is unset — every authenticated request returns HTTP 503.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_KEY=
